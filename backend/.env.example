APP_NAME=EducationClaw
APP_ENV=dev
APP_HOST=127.0.0.1
APP_PORT=8000
APP_DEBUG=true

OPENCLAW_BASE_URL=
OPENCLAW_API_KEY=
GLM_BASE_URL=https://open.bigmodel.cn/api/paas/v4/chat/completions
GLM_API_KEY=your_glm_api_key
DEEPSEEK_BASE_URL=https://api.deepseek.com/v1/chat/completions
DEEPSEEK_API_KEY=your_deepseek_api_key
MINIMAX_BASE_URL=https://api.minimaxi.com/v1
MINIMAX_API_KEY=your_minimax_api_key

REDIS_URL=redis://127.0.0.1:6379/0
MYSQL_DSN=mysql+pymysql://root:password@127.0.0.1:3306/educationclaw

MODEL_WHITELIST=MiniMax-M2.7,glm-5.1,DeepSeek-V3.2
DEFAULT_MODEL=MiniMax-M2.7
FALLBACK_MODEL=glm-5.1
MODEL_TIMEOUT_SECONDS=20
MODEL_MAX_RETRY=2
CIRCUIT_BREAK_FAILURES=3
CIRCUIT_BREAK_COOLDOWN_SECONDS=45
CACHE_TTL_SECONDS=1800
